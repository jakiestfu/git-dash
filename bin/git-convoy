#!/usr/bin/env bash
# git convoy — interactive TUI for managing stacked GitHub pull requests.
# Installed as both `git-convoy` and `git-cv`.

set -euo pipefail

if (( BASH_VERSINFO[0] < 4 )); then
	echo "git convoy requires bash >= 4 (this is $BASH_VERSION); try: brew install bash" >&2
	exit 1
fi

PR_LIMIT=100

USE_COLOR=1
[[ -t 1 && -z ${NO_COLOR:-} ]] || USE_COLOR=0

c() {
	if (( USE_COLOR )); then
		printf '\033[%sm%s\033[0m' "$1" "${*:2}"
	else
		printf '%s' "${*:2}"
	fi
}
red() { c 31 "$@"; }
green() { c 32 "$@"; }
yellow() { c 33 "$@"; }
cyan() { c 36 "$@"; }
grey() { c 90 "$@"; }
dim() { c 2 "$@"; }
bold() { c 1 "$@"; }

die() {
	if (( USE_COLOR )); then
		printf '\033[31m%s\033[0m\n' "$*" >&2
	else
		printf '%s\n' "$*" >&2
	fi
	exit 1
}

require_deps() {
	local cmd
	for cmd in git gh jq; do
		command -v "$cmd" >/dev/null 2>&1 || die "git convoy requires '$cmd'"
	done
	git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
}

repo_slug() {
	local url
	url=$(git remote get-url origin 2>/dev/null) || { echo ""; return; }
	url=${url%.git}
	url=${url#git@github.com:}
	url=${url#https://github.com/}
	echo "$url"
}

# ── Config ───────────────────────────────────────────────────────────────────
# Per-repo settings live in one JSON file in the user's home directory:
#   { "repos": { "owner/repo": { "showChecks": true,
#                                "actions": { "t": { "workflow": "x.yml",
#                                                    "name": "X" } } } } }

CONFIG_FILE="${GIT_CONVOY_CONFIG:-$HOME/.git-convoy.json}"
SHOW_CHECKS=1
declare -A ACTION_WF ACTION_NAME ACTION_RUN_ID

config_load() { # requires REPO_SLUG
	ACTION_WF=() ACTION_NAME=()
	SHOW_CHECKS=1
	[[ -f $CONFIG_FILE && -n $REPO_SLUG ]] || return 0

	local sc
	sc=$(jq -r --arg r "$REPO_SLUG" \
		'if .repos[$r].showChecks == false then 0 else 1 end' \
		"$CONFIG_FILE" 2>/dev/null) || sc=1
	[[ $sc == 0 ]] && SHOW_CHECKS=0

	local key wf name
	while IFS=$'\t' read -r key wf name; do
		[[ -n $key && -n $wf ]] || continue
		ACTION_WF[$key]=$wf
		ACTION_NAME[$key]=${name:-$wf}
	done < <(jq -r --arg r "$REPO_SLUG" \
		'.repos[$r].actions // {} | to_entries[] | [.key, .value.workflow, .value.name] | @tsv' \
		"$CONFIG_FILE" 2>/dev/null || true)
}

config_save() { # requires REPO_SLUG
	[[ -n $REPO_SLUG ]] || return 0

	local actions='{}' key
	for key in ${ACTION_WF[@]+"${!ACTION_WF[@]}"}; do
		actions=$(jq -n --argjson a "$actions" \
			--arg k "$key" --arg w "${ACTION_WF[$key]}" --arg n "${ACTION_NAME[$key]}" \
			'$a + {($k): {workflow: $w, name: $n}}')
	done

	local base='{}'
	if [[ -f $CONFIG_FILE ]] && jq empty "$CONFIG_FILE" >/dev/null 2>&1; then
		base=$(cat "$CONFIG_FILE")
	fi

	local tmp
	tmp=$(mktemp "${TMPDIR:-/tmp}/git-convoy-config.XXXXXX")
	jq -n --argjson base "$base" --arg r "$REPO_SLUG" \
		--argjson sc "$SHOW_CHECKS" --argjson actions "$actions" \
		'$base + {version: 1,
		          repos: (($base.repos // {}) +
		                  {($r): {showChecks: ($sc == 1), actions: $actions}})}' \
		>"$tmp" && mv "$tmp" "$CONFIG_FILE"
}

# ── PR data ──────────────────────────────────────────────────────────────────
# Both loaders fetch PRs as one TSV row each (title last: it may contain the
# separator) via the same jq program, which also folds statusCheckRollup down
# to "passed/total" plus a GitHub-style color: red if any check failed, else
# yellow if any is still pending, else green.

declare -A PR_BASE PR_NUM PR_ADDS PR_DELS PR_TITLE PR_DRAFT PR_CHECKS PR_CHECKS_COLOR
declare -A CHILDREN ROW_OF ROOT_ROW_OF

JQ_DEFS='
def verdict:
  ([.conclusion, .state, .status] | map(select(. != null and . != "")) | first // "")
  | ascii_upcase;
def checks_text:
  (.statusCheckRollup // []) as $c
  | if ($c | length) == 0 then "-"
    else "\([$c[] | select(verdict | IN("SUCCESS","NEUTRAL","SKIPPED"))] | length)/\($c | length)"
    end;
def checks_color:
  (.statusCheckRollup // []) as $c
  | if ($c | length) == 0 then "-"
    elif ([$c[] | select(verdict |
        IN("FAILURE","TIMED_OUT","CANCELLED","ACTION_REQUIRED","STARTUP_FAILURE","ERROR"))] | length) > 0
      then "red"
    elif ([$c[] | select(verdict | IN("SUCCESS","NEUTRAL","SKIPPED"))] | length) < ($c | length)
      then "yellow"
    else "green" end;
def row:
  [.headRefName, .baseRefName, (.number|tostring), (.additions|tostring),
   (.deletions|tostring), (.isDraft|tostring), checks_text, checks_color, .title]
  | @tsv;
'

pr_fields() {
	local f="number,title,headRefName,baseRefName,additions,deletions,isDraft,state"
	(( SHOW_CHECKS )) && f+=",statusCheckRollup"
	printf '%s' "$f"
}

# ingest_pr_line: tsv row -> assoc arrays; sets INGESTED_HEAD to the head
# branch. (Must not be called in a command substitution — the array writes
# would be lost in the subshell.)
INGESTED_HEAD=""
ingest_pr_line() {
	local head base num adds dels draft ct cc title
	IFS=$'\t' read -r head base num adds dels draft ct cc title <<<"$1"
	[[ -n $head ]] || return 1
	PR_BASE[$head]=$base
	PR_NUM[$head]=$num
	PR_ADDS[$head]=$adds
	PR_DELS[$head]=$dels
	PR_DRAFT[$head]=$draft
	PR_TITLE[$head]=$title
	[[ $ct == - ]] && ct=""
	case "$cc" in green | yellow | red) ;; *) cc="" ;; esac
	PR_CHECKS[$head]=$ct
	PR_CHECKS_COLOR[$head]=$cc
	INGESTED_HEAD=$head
}

# ── Stack model ──────────────────────────────────────────────────────────────
# Parallel arrays indexed in render order. Each stack starts with its root row
# at depth 0 (the branch with no open PR, e.g. main); ROOT_OF[i] names the
# stack root every row belongs to, so multiple stacks can coexist (--yours).

BRANCH=() PARENT=() DEPTH=() STATUS=() NOTE=() AHEAD=() BEHIND=() ROOT_OF=()
RNUM=() RTITLE=() RADDS=() RDELS=() RDRAFT=() RCHECKS=() RCHECKSCOL=()
ROOTS=()
CUR_BRANCH="" CURRENT_ROOT=""

add_row() { # branch parent depth
	local i=${#BRANCH[@]} b=$1
	BRANCH[i]=$b PARENT[i]=$2 DEPTH[i]=$3 ROOT_OF[i]=$CURRENT_ROOT
	STATUS[i]=idle NOTE[i]="" AHEAD[i]="?" BEHIND[i]="?"
	RNUM[i]=${PR_NUM[$b]:-} RTITLE[i]=${PR_TITLE[$b]:-}
	RADDS[i]=${PR_ADDS[$b]:-0} RDELS[i]=${PR_DELS[$b]:-0} RDRAFT[i]=${PR_DRAFT[$b]:-false}
	RCHECKS[i]=${PR_CHECKS[$b]:-} RCHECKSCOL[i]=${PR_CHECKS_COLOR[$b]:-}
	ROW_OF[$b]=$i
}

add_root_row() { # branch
	CURRENT_ROOT=$1
	ROOT_ROW_OF[$1]=${#BRANCH[@]}
	ROOTS+=("$1")
	add_row "$1" "" 0
}

add_subtree() { # branch depth
	local branch=$1 depth=$2
	add_row "$branch" "${PR_BASE[$branch]}" "$depth"

	local kids=() kid
	read -ra kids <<<"${CHILDREN[$branch]:-}"
	for kid in "${kids[@]}"; do
		add_subtree "$kid" $((depth + 1))
	done
}

# Default mode: one `gh pr view` for the current branch, then one per ancestor
# while walking up the bases — instead of listing every open PR in the repo.
load_stack_current() {
	CUR_BRANCH=$(git branch --show-current)
	[[ -n $CUR_BRANCH ]] || die "detached HEAD; check out a branch first"

	local fields b=$CUR_BRANCH chain=() line
	fields=$(pr_fields)
	while (( ${#chain[@]} < 50 )); do
		line=$(gh pr view "$b" --json "$fields" 2>/dev/null \
			| jq -r "${JQ_DEFS}"'select(.state == "OPEN") | row') || line=""
		[[ -n $line ]] || break
		ingest_pr_line "$line"
		chain=("$b" "${chain[@]}")
		b=${PR_BASE[$b]}
	done
	(( ${#chain[@]} > 0 )) || die "no open pull request found for branch '$CUR_BRANCH'"

	add_root_row "$b"
	local br depth=1
	for br in "${chain[@]}"; do
		add_row "$br" "${PR_BASE[$br]}" "$depth"
		depth=$((depth + 1))
	done
}

# --yours: every open PR you authored, grouped into stacks. A base that isn't
# one of your PRs (main, or someone else's PR branch) becomes a stack root.
load_stack_yours() {
	CUR_BRANCH=$(git branch --show-current || true)

	local fields rows line head
	fields=$(pr_fields)
	rows=$(gh pr list --author "@me" --state open --limit "$PR_LIMIT" --json "$fields" 2>/dev/null \
		| jq -r "${JQ_DEFS}"'.[] | row') \
		|| die "failed to list your pull requests (is 'gh' authenticated for this repo?)"

	local heads=()
	while IFS= read -r line; do
		[[ -n $line ]] || continue
		ingest_pr_line "$line" || continue
		head=$INGESTED_HEAD
		heads+=("$head")
		CHILDREN[${PR_BASE[$head]}]+="$head "
	done <<<"$rows"
	(( ${#heads[@]} > 0 )) || die "you have no open pull requests in this repo"

	local h base kid kids
	declare -A seen_root=()
	for h in "${heads[@]}"; do
		base=${PR_BASE[$h]}
		[[ -n ${PR_BASE[$base]:-} ]] && continue
		[[ -n ${seen_root[$base]:-} ]] && continue
		seen_root[$base]=1
		add_root_row "$base"
		kids=()
		read -ra kids <<<"${CHILDREN[$base]}"
		for kid in "${kids[@]}"; do
			add_subtree "$kid" 1
		done
	done
}

ref_for() { # branch -> local ref, origin ref, or empty
	if git rev-parse --verify --quiet "refs/heads/$1" >/dev/null; then
		echo "$1"
	elif git rev-parse --verify --quiet "refs/remotes/origin/$1" >/dev/null; then
		echo "origin/$1"
	else
		echo ""
	fi
}

load_git_stats() {
	local i b p bref pref
	for (( i = 0; i < ${#BRANCH[@]}; i++ )); do
		b=${BRANCH[i]} p=${PARENT[i]}
		if [[ -z $p ]]; then
			BEHIND[i]=$(git rev-list --count "$b..origin/$b" 2>/dev/null || echo "?")
			continue
		fi
		NOTE[i]=""
		git rev-parse --verify --quiet "refs/heads/$b" >/dev/null || NOTE[i]="no local branch"
		bref=$(ref_for "$b") pref=$(ref_for "$p")
		if [[ -n $bref && -n $pref ]]; then
			AHEAD[i]=$(git rev-list --count "$pref..$bref" 2>/dev/null || echo "?")
		else
			AHEAD[i]="?"
		fi
	done
}

# ── Rebase cascade ───────────────────────────────────────────────────────────

CHAIN=()
CHAIN_ROOT=""
CHAIN_ROOT_ROW=0
CASCADE_ERR=""
ORIG_BRANCH=""
declare -A OLD_PARENT_SHA

compute_chain() { # target row index -> CHAIN (bottom row first) within its stack
	CHAIN=()
	CHAIN_ROOT=${ROOT_OF[$1]}
	CHAIN_ROOT_ROW=${ROOT_ROW_OF[$CHAIN_ROOT]}
	local b=${BRANCH[$1]}
	while [[ -n $b && $b != "$CHAIN_ROOT" ]]; do
		CHAIN=("${ROW_OF[$b]}" "${CHAIN[@]}")
		b=${PR_BASE[$b]:-}
	done
}

rebase_in_progress() {
	local gd
	gd=$(git rev-parse --git-dir)
	[[ -d $gd/rebase-merge || -d $gd/rebase-apply ]]
}

abort_rebase_if_any() {
	if rebase_in_progress; then
		git rebase --abort >/dev/null 2>&1 || true
	fi
}

check_preconditions() {
	if [[ -z $CUR_BRANCH ]]; then
		CASCADE_ERR="detached HEAD; check out a branch first"
		return 1
	fi
	if rebase_in_progress; then
		CASCADE_ERR="a rebase is already in progress — finish or abort it first"
		return 1
	fi
	if ! git diff --quiet || ! git diff --cached --quiet; then
		CASCADE_ERR="working tree is dirty — commit or stash before rebasing"
		return 1
	fi
}

update_root() {
	git fetch origin --prune || return 1
	if [[ $ORIG_BRANCH == "$CHAIN_ROOT" ]]; then
		git merge --ff-only "origin/$CHAIN_ROOT"
	else
		# Fast-forward-only by definition; fails loudly if local root diverged.
		git fetch origin "$CHAIN_ROOT:$CHAIN_ROOT"
	fi
}

rebase_branch() { # branch parent old-parent-sha push
	local b=$1 p=$2 old=$3 push=$4
	git rebase --onto "$p" "$old" "$b" || return 1
	if (( push )); then
		git push --force-with-lease origin "$b" || return 1
	fi
}

restore_branch() {
	if [[ -n $ORIG_BRANCH && $(git branch --show-current) != "$ORIG_BRANCH" ]]; then
		git checkout --quiet "$ORIG_BRANCH" 2>/dev/null || true
	fi
}

cascade() { # target-row-index push(1|0)
	local target=$1 push=$2 r b p old n
	CASCADE_ERR=""

	check_preconditions || return 1
	compute_chain "$target"
	ORIG_BRANCH=$CUR_BRANCH

	# CHAIN is empty when the root itself is the target; ${arr[@]+...} keeps
	# the expansion safe under `set -u` on bash < 4.4.
	STATUS[CHAIN_ROOT_ROW]=pending
	for r in ${CHAIN[@]+"${CHAIN[@]}"}; do
		STATUS[$r]=pending
		NOTE[$r]=""
	done
	declare -F convoy_tick >/dev/null && convoy_tick

	if ! convoy_step "$CHAIN_ROOT_ROW" "updated" update_root; then
		CASCADE_ERR="could not update $CHAIN_ROOT — local $CHAIN_ROOT has diverged from origin/$CHAIN_ROOT"
		return 1
	fi

	# Root selected: pulling from origin is the whole job.
	if (( ${#CHAIN[@]} == 0 )); then
		restore_branch
		return 0
	fi

	# Create missing local branches, then fail early on any remote divergence
	# so we never leave the stack half-rebased for a foreseeable reason.
	for r in "${CHAIN[@]}"; do
		b=${BRANCH[$r]}
		if ! git rev-parse --verify --quiet "refs/heads/$b" >/dev/null; then
			if ! git fetch origin "$b:$b" >/dev/null 2>&1; then
				STATUS[$r]=fail
				CASCADE_ERR="branch '$b' has no local copy and could not be fetched"
				return 1
			fi
			NOTE[$r]="fetched"
		fi
		if git rev-parse --verify --quiet "refs/remotes/origin/$b" >/dev/null; then
			n=$(git rev-list --count "$b..origin/$b" 2>/dev/null || echo 0)
			if (( n > 0 )); then
				STATUS[$r]=fail
				CASCADE_ERR="origin/$b has $n commit(s) not in local '$b' — reconcile before rebasing"
				return 1
			fi
		fi
	done

	# Record every branch's fork point from its parent before any rebase runs;
	# once a parent is rebased, merge-base against it would land below the old
	# tip and replay the parent's own commits as duplicates. --fork-point
	# consults the parent's reflog, which also survives the parent having been
	# rebased outside convoy; plain merge-base is the fallback.
	OLD_PARENT_SHA=()
	for r in "${CHAIN[@]}"; do
		b=${BRANCH[$r]} p=${PARENT[$r]}
		OLD_PARENT_SHA[$r]=$(git merge-base --fork-point "$p" "$b" 2>/dev/null) \
			|| OLD_PARENT_SHA[$r]=$(git merge-base "$p" "$b")
	done

	for r in "${CHAIN[@]}"; do
		b=${BRANCH[$r]} p=${PARENT[$r]} old=${OLD_PARENT_SHA[$r]}
		if [[ $(git rev-parse "$p") == "$old" ]] && git merge-base --is-ancestor "$p" "$b" 2>/dev/null; then
			if (( push )) && [[ $(git rev-parse "$b") != $(git rev-parse "origin/$b" 2>/dev/null) ]]; then
				convoy_step "$r" "pushed" git push --force-with-lease origin "$b" || {
					CASCADE_ERR="push of '$b' failed"
					restore_branch
					return 1
				}
			else
				convoy_step "$r" "up to date" true || true
			fi
			continue
		fi

		if ! convoy_step "$r" "rebased$( (( push )) && printf ' · pushed')" rebase_branch "$b" "$p" "$old" "$push"; then
			abort_rebase_if_any
			CASCADE_ERR="rebase of '$b' failed — rebase aborted, repo left clean.
  Resolve manually: git rebase --onto $p $old $b"
			restore_branch
			return 1
		fi
	done

	restore_branch
}

# ── CLI ──────────────────────────────────────────────────────────────────────

PUSH=1
BASE_DIR=""
MODE=current
CONFIG_IMPORT=""

while [[ $# -gt 0 ]]; do
	case "$1" in
	--no-push)
		PUSH=0
		shift
		;;
	--dir)
		[[ $# -ge 2 ]] || die "--dir requires a path"
		BASE_DIR=$2
		shift 2
		;;
	--dir=*)
		BASE_DIR=${1#--dir=}
		shift
		;;
	--current)
		MODE=current
		shift
		;;
	--yours)
		MODE=yours
		shift
		;;
	--configure)
		MODE=configure
		shift
		if [[ $# -gt 0 && ${1:0:1} != - ]]; then
			CONFIG_IMPORT=$1
			shift
		fi
		;;
	--configure=*)
		MODE=configure
		CONFIG_IMPORT=${1#--configure=}
		shift
		;;
	-h | --help | help)
		cat <<EOF
Usage: git convoy [OPTIONS]     (also installed as: git cv)

Interactive view of the PR stack containing the current branch. The root
branch renders at the top; each PR below it, indented one space per level.
Filled radios (●) mark the branches the current selection would rebase;
empty radios (○) are left untouched.

OPTIONS:
  --current       Show the current branch's PR and its ancestors (default)
  --yours         Show all of your open PRs, grouped into stacks
  --configure [URL]
                  Open the settings UI: toggle the checks column and bind
                  keys to GitHub Actions workflows. With a URL (or local
                  path) to a shared JSON file, its action bindings are
                  downloaded and merged into this repo's config first —
                  handy for sharing team configurations
  --dir <path>    Run against the git repository at <path> instead of the
                  current directory
  --no-push       Rebase locally only; skip force-pushing
  -h, --help      Show this help message

KEYS:
  ↑/↓ or k/j      Move selection
  r               Rebase the selected PR's chain: the root is fast-forwarded
                  from origin, then every branch between the root and the
                  selection is rebased bottom-up and force-pushed (with lease).
                  With the root branch selected, this just pulls it from origin
  c               Check out the selected branch
  v               View the selected PR on GitHub
  <bound key>     Run the bound GitHub Actions workflow (a-z or 0-9, set up
                  via --configure) on the selected branch; press again to
                  open the dispatched run
  q               Quit

Settings are saved per-repo in ~/.git-convoy.json.
EOF
		exit 0
		;;
	*)
		echo "Unknown option: $1"
		echo "Run 'git convoy --help' for usage information"
		exit 1
		;;
	esac
done

if [[ -n $BASE_DIR ]]; then
	cd -- "$BASE_DIR" 2>/dev/null || die "cannot change to directory: $BASE_DIR"
fi

require_deps

REPO_SLUG=$(repo_slug)
config_load

SPIN_FRAMES='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
SPIN_I=0
DRAWN=0
SEL=1
BUSY=0
SEL_CHAIN=()
MESSAGE=""
INFO=""
STEP_LOG_TAIL=""
CUR_PID=""
LINES=()
WORKDIR=$(mktemp -d)

INTERACTIVE=1
[[ -t 0 && -t 1 ]] || INTERACTIVE=0

cleanup() {
	local rc=$?
	if (( INTERACTIVE )); then
		printf '\033[?25h'
		stty sane 2>/dev/null || true
	fi
	if [[ -n $CUR_PID ]]; then
		kill "$CUR_PID" 2>/dev/null || true
	fi
	abort_rebase_if_any
	restore_branch
	rm -rf "$WORKDIR"
	exit "$rc"
}
trap cleanup EXIT
trap 'exit 130' INT TERM

# paint: redraw LINES in place (shared by the main and configure views).
paint() {
	local out="" line
	if (( DRAWN > 0 )); then
		out+=$'\033['"${DRAWN}A"$'\r'
	fi
	for line in "${LINES[@]}"; do
		out+=$'\033[2K'"$line"$'\n'
	done
	out+=$'\033[0J'
	printf '%s' "$out"
	DRAWN=${#LINES[@]}
}

# ── Configure view ───────────────────────────────────────────────────────────
# Letters the main view already uses; they can't be bound to workflows.
RESERVED_KEYS="jkqrcv"

# import_actions: fetch a shared JSON file (URL or local path) and merge its
# action bindings into this repo's config. The file may be a full config
# (bindings read from .repos["owner/repo"].actions) or a bare fragment with a
# top-level "actions" object. Imported bindings win over local ones — both
# for the same key and for the same workflow — and reserved keys are skipped.
import_actions() { # url-or-path
	local src=$1 file="$WORKDIR/import.json"

	if [[ -f $src ]]; then
		cp -- "$src" "$file"
	elif command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src" -o "$file" || die "could not download '$src'"
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$file" "$src" || die "could not download '$src'"
	else
		die "need curl or wget to download '$src'"
	fi
	jq empty "$file" 2>/dev/null || die "'$src' is not valid JSON"

	local imported=0 skipped="" key wf name k
	while IFS=$'\t' read -r key wf name; do
		[[ -n $key && -n $wf ]] || continue
		if [[ ${#key} -ne 1 || $RESERVED_KEYS == *"$key"* ]]; then
			skipped+=" $key"
			continue
		fi
		# Same stealing semantics as the configure UI: one key per workflow.
		for k in ${ACTION_WF[@]+"${!ACTION_WF[@]}"}; do
			[[ ${ACTION_WF[$k]} == "$wf" ]] && unset "ACTION_WF[$k]" "ACTION_NAME[$k]"
		done
		ACTION_WF[$key]=$wf
		ACTION_NAME[$key]=${name:-$wf}
		imported=$(( imported + 1 ))
	done < <(jq -r --arg r "$REPO_SLUG" \
		'(.repos[$r].actions // .actions // {})
		 | to_entries[] | [.key, .value.workflow, .value.name] | @tsv' \
		"$file" 2>/dev/null || true)

	(( imported > 0 )) || die "no usable action bindings found in '$src'"
	config_save
	printf '%s\n' "$(green "imported $imported action binding(s) from $src")"
	[[ -n $skipped ]] && printf '%s\n' "$(yellow "skipped reserved/invalid key(s):$skipped")"
	return 0
}

run_configure() {
	(( INTERACTIVE )) || die "--configure requires an interactive terminal (or a URL to import)"

	local WF_ID=() WF_NAME=() rows p n
	rows=$(gh workflow list --json name,path,state 2>/dev/null \
		| jq -r '.[] | select(.state == "ACTIVE" or .state == "active") | [.path, .name] | @tsv') || rows=""
	while IFS=$'\t' read -r p n; do
		[[ -n $p ]] || continue
		WF_ID+=("$(basename -- "$p")")
		WF_NAME+=("${n:-$p}")
	done <<<"$rows"

	local CSEL=0 CMSG="" last=${#WF_ID[@]}

	key_of_wf() { # workflow-id -> bound key or empty
		local k
		for k in ${ACTION_WF[@]+"${!ACTION_WF[@]}"}; do
			if [[ ${ACTION_WF[$k]} == "$1" ]]; then
				printf '%s' "$k"
				return
			fi
		done
	}

	cbuild() {
		LINES=()
		LINES+=("")
		LINES+=("  $(bold "convoy settings")$(dim " · ${REPO_SLUG:-local}")")
		LINES+=("")

		local cur=" " state
		(( CSEL == 0 )) && cur=$(bold "$(cyan "❯")")
		if (( SHOW_CHECKS )); then state=$(green "[on]"); else state=$(dim "[off]"); fi
		LINES+=("  $cur Show checks $state $(dim "· [passed/total] check status on each PR")")
		LINES+=("")

		LINES+=("  $(dim "action keys")")
		if (( ${#WF_ID[@]} == 0 )); then
			LINES+=("      $(dim "no active workflows found in this repo")")
		fi
		local i k disp
		for (( i = 0; i < ${#WF_ID[@]}; i++ )); do
			cur=" "
			(( CSEL == i + 1 )) && cur=$(bold "$(cyan "❯")")
			k=$(key_of_wf "${WF_ID[i]}")
			if [[ -n $k ]]; then disp=$(bold "$(cyan "$k")"); else disp=$(dim "—"); fi
			LINES+=("  $cur $disp  ${WF_NAME[i]} $(dim "· ${WF_ID[i]}")")
		done

		LINES+=("")
		LINES+=("  $(dim "↑↓ move · space toggle · a-z 0-9 bind · enter rename · esc unbind · q quit")")
		if [[ -n $CMSG ]]; then
			LINES+=("")
			LINES+=("  $(yellow "$CMSG")")
		fi
	}

	crender() {
		cbuild
		paint
	}

	# Rename how a bound action is shown (in the footer and this list); the
	# name is only stored in the local user's config. Reads one echoed line
	# below the UI, which paint() then reclaims.
	rename_selected() {
		local wf=${WF_ID[CSEL - 1]} k new=""
		k=$(key_of_wf "$wf")
		if [[ -z $k ]]; then
			CMSG="bind a key before renaming"
			return 0
		fi
		printf '\033[?25h'
		IFS= read -er -p "  rename '${ACTION_NAME[$k]}' to: " new || new=""
		printf '\033[?25l'
		DRAWN=$(( DRAWN + 1 ))
		if [[ -n $new ]]; then
			ACTION_NAME[$k]=$new
			WF_NAME[CSEL - 1]=$new
			config_save
		fi
	}

	printf '\033[?25l'
	crender

	local key rest wf k prev
	while true; do
		IFS= read -rsn1 key || break
		CMSG=""
		if [[ $key == $'\x1b' ]]; then
			rest=""
			read -rsn2 -t 0.01 rest || true
			key+=$rest
		fi
		case "$key" in
		$'\x1b[A' | k)
			(( CSEL > 0 )) && CSEL=$(( CSEL - 1 ))
			crender
			;;
		$'\x1b[B' | j)
			(( CSEL < last )) && CSEL=$(( CSEL + 1 ))
			crender
			;;
		' ' | "")
			if (( CSEL == 0 )); then
				SHOW_CHECKS=$(( 1 - SHOW_CHECKS ))
				config_save
			elif [[ $key == "" ]]; then
				rename_selected
			fi
			crender
			;;
		$'\x1b')
			if (( CSEL > 0 )); then
				wf=${WF_ID[CSEL - 1]}
				k=$(key_of_wf "$wf")
				if [[ -n $k ]]; then
					unset "ACTION_WF[$k]" "ACTION_NAME[$k]"
					config_save
				fi
			fi
			crender
			;;
		q)
			break
			;;
		[a-z0-9])
			if (( CSEL > 0 )); then
				if [[ $RESERVED_KEYS == *"$key"* ]]; then
					CMSG="'$key' is reserved ($RESERVED_KEYS)"
				else
					wf=${WF_ID[CSEL - 1]}
					prev=$(key_of_wf "$wf")
					[[ -n $prev ]] && unset "ACTION_WF[$prev]" "ACTION_NAME[$prev]"
					# Assigning an already-used key steals it from the other workflow.
					ACTION_WF[$key]=$wf
					ACTION_NAME[$key]=${WF_NAME[CSEL - 1]}
					config_save
				fi
			fi
			crender
			;;
		esac
	done
}

if [[ $MODE == configure ]]; then
	[[ -n $CONFIG_IMPORT ]] && import_actions "$CONFIG_IMPORT"
	if (( INTERACTIVE )) || [[ -z $CONFIG_IMPORT ]]; then
		run_configure
	fi
	exit 0
fi

# ── Main view ────────────────────────────────────────────────────────────────

# Radio semantics: filled ● marks rows the current selection would rebase
# (the stack root plus the chain up to SEL), the selected row's radio is bold,
# and everything else is an empty ○. While a rebase runs, idle radios go grey.
glyph_for() {
	case "${STATUS[$1]}" in
	running) cyan "${SPIN_FRAMES:SPIN_I % 10:1}" ;;
	ok) green "✓" ;;
	fail) red "✗" ;;
	*)
		if [[ ${STATUS[$1]} == pending || -n ${SEL_CHAIN[$1]:-} ]]; then
			if (( BUSY )); then
				grey "●"
			elif (( $1 == SEL )); then
				bold "$(cyan "●")"
			else
				cyan "●"
			fi
		else
			(( BUSY )) && grey "○" || dim "○"
		fi
		;;
	esac
}

# Mark the rows a rebase of SEL would touch: the stack's root plus every
# branch between it and the selection.
mark_sel_chain() {
	SEL_CHAIN=()
	local root=${ROOT_OF[SEL]:-}
	[[ -n $root ]] || return 0
	SEL_CHAIN[${ROOT_ROW_OF[$root]}]=1
	local b=${BRANCH[SEL]:-}
	while [[ -n $b && $b != "$root" ]]; do
		SEL_CHAIN[${ROW_OF[$b]}]=1
		b=${PR_BASE[$b]:-}
	done
}

action_hints() {
	local out="" k
	(( ${#ACTION_WF[@]} > 0 )) || return 0
	while IFS= read -r k; do
		[[ -n $out ]] && out+=" · "
		if [[ -n ${ACTION_RUN_ID[$k]:-} ]]; then
			out+="$k view"
		else
			out+="$k ${ACTION_NAME[$k],,}"
		fi
	done < <(printf '%s\n' "${!ACTION_WF[@]}" | sort)
	printf '%s' "$out"
}

build_lines() {
	LINES=()
	LINES+=("")
	LINES+=("  $(bold "convoy")$(dim " · ${REPO_SLUG:-local}")")
	LINES+=("")

	mark_sel_chain

	local cols i cursor g bname checks note title meta max ind
	cols=$(tput cols 2>/dev/null || echo 120)

	for (( i = 0; i < ${#BRANCH[@]}; i++ )); do
		cursor=" "
		if (( INTERACTIVE )) && (( i == SEL )); then
			cursor=$(bold "$(cyan "❯")")
			(( BUSY )) && cursor=$(grey "❯")
		fi

		if [[ -z ${PARENT[i]} ]]; then
			(( i > 0 )) && LINES+=("")
			local behind
			if [[ ${BEHIND[i]} == "?" ]]; then
				behind=$(dim "· origin unknown")
			elif (( BEHIND[i] > 0 )); then
				behind=$(yellow "· ${BEHIND[i]} behind origin")
			else
				behind=$(dim "· up to date")
			fi
			LINES+=("  $cursor $(glyph_for "$i") $(bold "${BRANCH[i]}") $behind")
			continue
		fi

		# Every PR row sits one level below its parent: the root's children at
		# depth 1 get one space, theirs two, and so on.
		ind=$(printf '%*s' "${DEPTH[i]}" '')
		g=$(glyph_for "$i")

		bname=$(cyan "${BRANCH[i]}")
		[[ ${BRANCH[i]} == "$CUR_BRANCH" ]] && bname=$(bold "$(cyan "${BRANCH[i]}")")
		checks=""
		if (( SHOW_CHECKS )) && [[ -n ${RCHECKS[i]} ]]; then
			checks=" $("${RCHECKSCOL[i]}" "[${RCHECKS[i]}]")"
		fi
		bname+=$checks
		[[ ${BRANCH[i]} == "$CUR_BRANCH" ]] && bname+=$(grey " ← you are here")
		note=""
		[[ ${RDRAFT[i]} == true ]] && note=" $(yellow "[draft]")"
		[[ -n ${NOTE[i]} ]] && note+=$(grey " · ${NOTE[i]}")
		LINES+=("  $ind$cursor $g $bname$note")

		title=${RTITLE[i]}
		max=$(( cols - ${#ind} - 32 ))
		(( max < 12 )) && max=12
		(( ${#title} > max )) && title="${title:0:max-1}…"
		meta="$(dim "#${RNUM[i]}") $title  $(green "+${RADDS[i]}") $(red "−${RDELS[i]}")$(dim " · ${AHEAD[i]} ahead")"
		LINES+=("  $ind    $meta")
	done

	LINES+=("")
	if (( INTERACTIVE )); then
		LINES+=("  $(dim "↑↓ move · r rebase · c checkout · v view on github · q quit")")
		local hints
		hints=$(action_hints)
		[[ -n $hints ]] && LINES+=("  $(dim "$hints")")
	fi
	if [[ -n $INFO ]]; then
		LINES+=("")
		LINES+=("  $(dim "$INFO")")
	fi
	if [[ -n $MESSAGE ]]; then
		LINES+=("")
		while IFS= read -r line; do
			LINES+=("  $(red "$line")")
		done <<<"$MESSAGE"
	fi
	if [[ -n $STEP_LOG_TAIL ]]; then
		while IFS= read -r line; do
			LINES+=("    $(grey "$line")")
		done <<<"$STEP_LOG_TAIL"
	fi
}

render() {
	build_lines
	paint
}

# convoy_step: run one cascade step in the background, animating the row's
# spinner until it exits. See the cascade section for the contract.
convoy_step() {
	local i=$1 note=$2
	shift 2
	STATUS[$i]=running
	local log="$WORKDIR/step.log"

	"$@" >"$log" 2>&1 &
	CUR_PID=$!
	while kill -0 "$CUR_PID" 2>/dev/null; do
		SPIN_I=$(( SPIN_I + 1 ))
		render
		sleep 0.08
	done

	local rc=0
	wait "$CUR_PID" || rc=$?
	CUR_PID=""
	if (( rc == 0 )); then
		STATUS[$i]=ok
		[[ -n $note ]] && NOTE[$i]=$note
	else
		STATUS[$i]=fail
		STEP_LOG_TAIL=$(tail -n 6 "$log" 2>/dev/null || true)
	fi
	render
	return "$rc"
}

convoy_tick() {
	render
}

start_rebase() {
	MESSAGE=""
	INFO=""
	STEP_LOG_TAIL=""
	local i
	for (( i = 0; i < ${#BRANCH[@]}; i++ )); do
		STATUS[$i]=idle
	done
	BUSY=1
	render
	if ! cascade "$SEL" "$PUSH"; then
		MESSAGE=$CASCADE_ERR
	fi
	BUSY=0
	load_git_stats
	render
}

checkout_selected() {
	MESSAGE=""
	INFO=""
	local b=${BRANCH[SEL]}
	if git checkout --quiet "$b" >"$WORKDIR/checkout.log" 2>&1; then
		CUR_BRANCH=$b
		# The user chose this branch; don't restore the old one on exit.
		ORIG_BRANCH=""
		NOTE[SEL]=""
	else
		MESSAGE="checkout of '$b' failed"
		STEP_LOG_TAIL=$(tail -n 6 "$WORKDIR/checkout.log" 2>/dev/null || true)
	fi
	render
}

open_selected_pr() {
	local num=${RNUM[SEL]:-}
	[[ -n $num ]] || return 0
	gh pr view "$num" --web >/dev/null 2>&1 || true
}

# First press dispatches the bound workflow on the selected row's branch;
# once a run id is known, the hint flips to "view" and pressing the key again
# opens that run in the browser.
run_action_key() {
	local key=$1 wf=${ACTION_WF[$1]} name=${ACTION_NAME[$1]} ref=${BRANCH[SEL]}

	if [[ -n ${ACTION_RUN_ID[$key]:-} ]]; then
		gh run view "${ACTION_RUN_ID[$key]}" --web >/dev/null 2>&1 || true
		return 0
	fi

	MESSAGE=""
	STEP_LOG_TAIL=""
	INFO="dispatching '$name' on ${ref}…"
	render
	if ! gh workflow run "$wf" --ref "$ref" >"$WORKDIR/action.log" 2>&1; then
		INFO=""
		MESSAGE="failed to dispatch '$name' on $ref"
		STEP_LOG_TAIL=$(tail -n 6 "$WORKDIR/action.log" 2>/dev/null || true)
		render
		return 0
	fi

	# Dispatch is async; give the run a moment to appear so we can link to it.
	local id="" try
	for try in 1 2 3; do
		sleep 1
		id=$(gh run list --workflow "$wf" --branch "$ref" --limit 1 \
			--json databaseId --jq '.[0].databaseId // empty' 2>/dev/null) || id=""
		[[ -n $id ]] && break
	done
	if [[ -n $id ]]; then
		ACTION_RUN_ID[$key]=$id
		INFO="'$name' running on $ref — press '$key' again to view"
	else
		INFO="'$name' dispatched on $ref"
	fi
	render
}

input_loop() {
	local key rest last=$(( ${#BRANCH[@]} - 1 ))
	while true; do
		IFS= read -rsn1 key || break
		if [[ $key == $'\x1b' ]]; then
			rest=""
			read -rsn2 -t 0.01 rest || true
			key+=$rest
		fi
		case "$key" in
		$'\x1b[A' | k)
			(( SEL > 0 )) && SEL=$(( SEL - 1 ))
			render
			;;
		$'\x1b[B' | j)
			(( SEL < last )) && SEL=$(( SEL + 1 ))
			render
			;;
		r)
			start_rebase
			;;
		c)
			checkout_selected
			;;
		v)
			open_selected_pr
			;;
		q)
			break
			;;
		*)
			if [[ ${#key} -eq 1 && -n ${ACTION_WF[$key]:-} ]]; then
				run_action_key "$key"
			fi
			;;
		esac
	done
}

(( INTERACTIVE )) && printf '%s' "$(dim "loading pull requests…")"
if [[ $MODE == yours ]]; then
	load_stack_yours
else
	load_stack_current
fi
(( INTERACTIVE )) && printf '\r\033[2K'
(( INTERACTIVE )) && printf '%s' "$(dim "fetching origin…")"
for root in "${ROOTS[@]}"; do
	git fetch origin "$root" --quiet 2>/dev/null || true
done
(( INTERACTIVE )) && printf '\r\033[2K'
load_git_stats
SEL=1
[[ -n $CUR_BRANCH ]] && SEL=${ROW_OF[$CUR_BRANCH]:-1}

if (( ! INTERACTIVE )); then
	build_lines
	printf '%s\n' "${LINES[@]}"
	exit 0
fi

printf '\033[?25l'
render
input_loop
