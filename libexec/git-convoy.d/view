#!/usr/bin/env bash
# Description: Interactive PR-stack list; select a PR and refresh its chain

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=_lib
source "$SCRIPT_DIR/_lib"

PUSH=1

while [[ $# -gt 0 ]]; do
	case "$1" in
	--no-push)
		PUSH=0
		shift
		;;
	-h | --help)
		cat <<EOF
Usage: git convoy [view] [OPTIONS]     (also installed as: git cv)

Interactive list of the PR stack containing the current branch.
The root branch renders at the top; each PR follows in stack order,
indented one space per level. Filled radios (вЧП) mark the branches the
current selection would refresh; empty radios (вЧЛ) are left untouched.

Select a PR with the arrow keys and press Enter to refresh it: the root
is fast-forwarded from origin, then every branch between the root and
the selection is rebased bottom-up and force-pushed (with lease).

OPTIONS:
  --no-push       Rebase locally only; skip force-pushing
  -h, --help      Show this help message

KEYS:
  вЖС/вЖУ or k/j      Move selection
  enter or r      Refresh the selected PR's chain
  q               Quit
EOF
		exit 0
		;;
	*)
		echo "Unknown option: $1"
		echo "Run 'git convoy view --help' for usage information"
		exit 1
		;;
	esac
done

require_deps

REPO_SLUG=$(repo_slug)
SPIN_FRAMES='в†Лв†Щв†єв†Єв†Љв†ів†¶в†Ів†Зв†П'
SPIN_I=0
DRAWN=0
SEL=1
BUSY=0
SEL_CHAIN=()
MESSAGE=""
STEP_LOG_TAIL=""
CUR_PID=""
LINES=()
WORKDIR=$(mktemp -d)

INTERACTIVE=1
[[ -t 0 && -t 1 ]] || INTERACTIVE=0

cleanup() {
	local rc=$?
	if (( INTERACTIVE )); then
		printf '\033[?25h'
		stty sane 2>/dev/null || true
	fi
	if [[ -n $CUR_PID ]]; then
		kill "$CUR_PID" 2>/dev/null || true
	fi
	abort_rebase_if_any
	restore_branch
	rm -rf "$WORKDIR"
	exit "$rc"
}
trap cleanup EXIT
trap 'exit 130' INT TERM

# Radio semantics: filled вЧП marks rows the current selection would refresh
# (the root plus the chain up to SEL), the selected row's radio is bold, and
# everything else is an empty вЧЛ. While a refresh runs, idle radios go grey.
glyph_for() {
	case "${STATUS[$1]}" in
	running) cyan "${SPIN_FRAMES:SPIN_I % 10:1}" ;;
	ok) green "вЬУ" ;;
	fail) red "вЬЧ" ;;
	*)
		if [[ ${STATUS[$1]} == pending || -n ${SEL_CHAIN[$1]:-} ]]; then
			if (( BUSY )); then
				grey "вЧП"
			elif (( $1 == SEL )); then
				bold "$(cyan "вЧП")"
			else
				cyan "вЧП"
			fi
		else
			(( BUSY )) && grey "вЧЛ" || dim "вЧЛ"
		fi
		;;
	esac
}

# Mark the rows a refresh of SEL would touch: the root plus every branch
# between it and the selection.
mark_sel_chain() {
	SEL_CHAIN=()
	SEL_CHAIN[0]=1
	local b=${BRANCH[SEL]:-}
	while [[ -n $b && $b != "$ROOT" ]]; do
		SEL_CHAIN[${ROW_OF[$b]}]=1
		b=${PR_BASE[$b]:-}
	done
}

build_lines() {
	LINES=()
	LINES+=("")
	LINES+=("  $(bold "convoy")$(dim " ¬Ј ${REPO_SLUG:-local}")")
	LINES+=("")

	mark_sel_chain

	local cols i cursor g bname note title meta max ind
	cols=$(tput cols 2>/dev/null || echo 120)

	for (( i = 0; i < ${#BRANCH[@]}; i++ )); do
		if [[ -z ${PARENT[i]} ]]; then
			local behind
			if [[ $ROOT_BEHIND == "?" ]]; then
				behind=$(dim "¬Ј origin unknown")
			elif (( ROOT_BEHIND > 0 )); then
				behind=$(yellow "¬Ј $ROOT_BEHIND behind origin")
			else
				behind=$(dim "¬Ј up to date")
			fi
			LINES+=("    $(glyph_for "$i") $(bold "${BRANCH[i]}") $behind")
			continue
		fi

		ind=""
		(( DEPTH[i] > 1 )) && ind=$(printf '%*s' $(( DEPTH[i] - 1 )) '')

		cursor=" "
		if (( INTERACTIVE )) && (( i == SEL )); then
			cursor=$(bold "$(cyan "вЭѓ")")
			(( BUSY )) && cursor=$(grey "вЭѓ")
		fi
		g=$(glyph_for "$i")

		bname=$(cyan "${BRANCH[i]}")
		if [[ ${BRANCH[i]} == "$CUR_BRANCH" ]]; then
			bname="$(bold "$(cyan "${BRANCH[i]}")")$(grey " вЖР you are here")"
		fi
		note=""
		[[ ${RDRAFT[i]} == true ]] && note=" $(yellow "[draft]")"
		[[ -n ${NOTE[i]} ]] && note+=$(grey " ¬Ј ${NOTE[i]}")
		LINES+=("  $ind$cursor $g $bname$note")

		title=${RTITLE[i]}
		max=$(( cols - ${#ind} - 32 ))
		(( max < 12 )) && max=12
		(( ${#title} > max )) && title="${title:0:max-1}вА¶"
		meta="$(dim "#${RNUM[i]}") $title  $(green "+${RADDS[i]}") $(red "вИТ${RDELS[i]}")$(dim " ¬Ј ${AHEAD[i]} ahead")"
		LINES+=("  $ind    $meta")
	done

	LINES+=("")
	if (( INTERACTIVE )); then
		LINES+=("  $(dim "вЖСвЖУ move ¬Ј enter refresh ¬Ј q quit")")
	fi
	if [[ -n $MESSAGE ]]; then
		LINES+=("")
		while IFS= read -r line; do
			LINES+=("  $(red "$line")")
		done <<<"$MESSAGE"
	fi
	if [[ -n $STEP_LOG_TAIL ]]; then
		while IFS= read -r line; do
			LINES+=("    $(grey "$line")")
		done <<<"$STEP_LOG_TAIL"
	fi
}

render() {
	build_lines
	local out="" line
	if (( DRAWN > 0 )); then
		out+=$'\033['"${DRAWN}A"$'\r'
	fi
	for line in "${LINES[@]}"; do
		out+=$'\033[2K'"$line"$'\n'
	done
	out+=$'\033[0J'
	printf '%s' "$out"
	DRAWN=${#LINES[@]}
}

# convoy_step: run one cascade step in the background, animating the row's
# spinner until it exits. See _lib for the contract.
convoy_step() {
	local i=$1 note=$2
	shift 2
	STATUS[$i]=running
	local log="$WORKDIR/step.log"

	"$@" >"$log" 2>&1 &
	CUR_PID=$!
	while kill -0 "$CUR_PID" 2>/dev/null; do
		SPIN_I=$(( SPIN_I + 1 ))
		render
		sleep 0.08
	done

	local rc=0
	wait "$CUR_PID" || rc=$?
	CUR_PID=""
	if (( rc == 0 )); then
		STATUS[$i]=ok
		[[ -n $note ]] && NOTE[$i]=$note
	else
		STATUS[$i]=fail
		STEP_LOG_TAIL=$(tail -n 6 "$log" 2>/dev/null || true)
	fi
	render
	return "$rc"
}

convoy_tick() {
	render
}

start_refresh() {
	MESSAGE=""
	STEP_LOG_TAIL=""
	local i
	for (( i = 0; i < ${#BRANCH[@]}; i++ )); do
		STATUS[$i]=idle
	done
	BUSY=1
	render
	if ! cascade "$SEL" "$PUSH"; then
		MESSAGE=$CASCADE_ERR
	fi
	BUSY=0
	load_git_stats
	render
}

input_loop() {
	local key rest last=$(( ${#BRANCH[@]} - 1 ))
	while true; do
		IFS= read -rsn1 key || break
		if [[ $key == $'\x1b' ]]; then
			rest=""
			read -rsn2 -t 0.01 rest || true
			key+=$rest
		fi
		case "$key" in
		$'\x1b[A' | k)
			(( SEL > 1 )) && SEL=$(( SEL - 1 ))
			render
			;;
		$'\x1b[B' | j)
			(( SEL < last )) && SEL=$(( SEL + 1 ))
			render
			;;
		"" | r)
			start_refresh
			;;
		q)
			break
			;;
		esac
	done
}

(( INTERACTIVE )) && printf '%s' "$(dim "loading pull requestsвА¶")"
load_prs
(( INTERACTIVE )) && printf '\r\033[2K'
build_stack
(( INTERACTIVE )) && printf '%s' "$(dim "fetching origin/${ROOT}вА¶")"
git fetch origin "$ROOT" --quiet 2>/dev/null || true
(( INTERACTIVE )) && printf '\r\033[2K'
load_git_stats
SEL=${ROW_OF[$CUR_BRANCH]:-1}

if (( ! INTERACTIVE )); then
	build_lines
	printf '%s\n' "${LINES[@]}"
	exit 0
fi

printf '\033[?25l'
render
input_loop
